{
    "name": "rielagroup/filament-spatie-states-diagram-history",
    "description": "Filament plugin: Spatie state diagram with history path and state history actions",
    "keywords": ["filament", "spatie", "model-states", "state-diagram", "laravel"],
    "license": "MIT",
    "authors": [
        {
            "name": "Riela Group",
            "homepage": "https://github.com/RielaGroup"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "spatie/laravel-model-states": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "RielaGroup\\FilamentSpatieStatesDiagramHistory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RielaGroup\\FilamentSpatieStatesDiagramHistory\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RielaGroup\\FilamentSpatieStatesDiagramHistory\\FilamentSpatieStatesDiagramHistoryServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
